{
  "version": "1",
  "providers": [
    {
      "id": "kimi",
      "name": "Kimi",
      "description": "Moonshot AI's coding model",
      "models": "Kimi-for-Coding",
      "base_url": "https://api.kimi.com/coding/",
      "api_key_var": "KIMI_API_KEY",
      "api_link": "https://platform.moonshot.cn/docs/api/chat",
      "env_vars": {
        "ANTHROPIC_MODEL": "kimi-for-coding",
        "ANTHROPIC_SMALL_FAST_MODEL": "kimi-for-coding"
      }
    },
    {
      "id": "glm",
      "name": "GLM (Z.AI)",
      "description": "Z.AI's GLM models",
      "models": "GLM-4.7 / GLM-4.5-Air",
      "base_url": "https://api.z.ai/api/anthropic",
      "api_key_var": "ZAI_API_KEY",
      "api_link": "https://z.ai/zh-ai/welcome",
      "env_vars": {
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-4.7",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-4.7",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-4.5-air"
      }
    },
    {
      "id": "minimax",
      "name": "MiniMax",
      "description": "MiniMax AI's text model",
      "models": "MiniMax-Text-01",
      "base_url": "https://api.minimax.chat/v1",
      "api_key_var": "MINIMAX_API_KEY",
      "api_link": "https://www.minimax.io/",
      "env_vars": {
        "ANTHROPIC_MODEL": "MiniMax-Text-01",
        "ANTHROPIC_SMALL_FAST_MODEL": "MiniMax-Text-01"
      }
    }
  ]
}
